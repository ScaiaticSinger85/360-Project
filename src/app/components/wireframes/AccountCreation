try {
      const response = await fetch('http://localhost:4000/api/accounts', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(account)
      });
      const data = await response.json();
      if (response.ok) {
        setResponseMessage(`Success: ${data.message}`);
